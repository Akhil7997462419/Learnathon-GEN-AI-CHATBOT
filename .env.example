# ============================================================
#  KLU Smart Assistant — Environment Variables
#  Copy this file to .env and fill in your values
#  DO NOT commit the actual .env file to version control
# ============================================================

# ── LLM API Keys ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
HF_API_TOKEN=hf_your_huggingface_token_here

# ── Active LLM Provider ────────────────────────────────────
# Options: openai | ollama | huggingface
LLM_PROVIDER=ollama

# ── Ollama (Local LLM) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── University Database (MySQL) ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=klu_university_db
DB_USER=klu_admin
DB_PASSWORD=your_secure_password_here

# ── Vector Store ───────────────────────────────────────────
CHROMA_PERSIST_DIR=./vector_db/chroma
FAISS_INDEX_DIR=./vector_db/faiss

# ── Embedding Model ────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ── Flask API Server ───────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Security ───────────────────────────────────────────────
SECRET_KEY=your-flask-secret-key-change-this
JWT_SECRET=your-jwt-secret-for-auth
CORS_ORIGINS=http://localhost:3000,http://localhost:5500
